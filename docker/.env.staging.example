# ─────────────────────────────────────────────────────────────────
# FaceHRM — Staging Environment Variables
# cp docker/.env.staging.example docker/.env.staging
# Jangan commit .env.staging ke git!
# ─────────────────────────────────────────────────────────────────

# Generate dengan: php artisan key:generate --show
APP_KEY=base64:GANTI_DENGAN_KEY_DARI_ARTISAN_KEY_GENERATE

APP_URL=http://localhost:8080

# Database
DB_DATABASE=facehrm_staging
DB_USERNAME=facehrm_user
DB_PASSWORD=GANTI_PASSWORD_KUAT_STAGING

# Sanctum — sesuaikan dengan domain/port staging
SANCTUM_STATEFUL_DOMAINS=localhost:8080
